# Copy to .env and fill in per environment. Never commit .env.
WEBTV_BASE_URL=https://preview-qa-review-ae007b75.viktor.space
UCTV_BASE_URL=
# Test account credentials (staging only)
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# --- Appium (local) ---
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723
# leave empty for local Appium; set to "sauce" for Sauce Labs
APPIUM_PROVIDER=

# Mobile app local binaries (APK / simulator .app or IPA)
# Prefer release/offline APK for Appium (debug builds may try to reach Metro).
MOBILE_APP_ANDROID_APP=./apps/mobile-app/android/app-release.apk
MOBILE_APP_IOS_APP=./apps/mobile-app/ios/GStream.app
ANDROID_DEVICE_NAME=Android Emulator
IOS_DEVICE_NAME=GStream_iPhone
IOS_PLATFORM_VERSION=26.5

# AStream local binaries (set when app is available)
ASTREAM_ANDROID_APP=
ASTREAM_IOS_APP=
ASTREAM_APP_PACKAGE=com.astream.auth
ASTREAM_BUNDLE_ID=com.astream.auth

# --- Sauce Labs (later) ---
SAUCE_USERNAME=
SAUCE_ACCESS_KEY=
MOBILE_APP_SAUCE_APP=
ASTREAM_SAUCE_APP=
SAUCE_DEVICE_NAME=
SAUCE_PLATFORM_VERSION=
SAUCE_BUILD=
