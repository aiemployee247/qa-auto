{
  "name": "qa-auto",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform QA automation (Playwright + TypeScript). Specs are named after Jira ticket + Xray test case IDs.",
  "scripts": {
    "test": "playwright test",
    "test:webtv": "playwright test --project=webtv",
    "test:smoke:webtv": "playwright test --project=webtv --grep @smoke",
    "test:uctv": "playwright test --project=uctv",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "@types/node": "^20",
    "typescript": "^5.6.0"
  }
}
